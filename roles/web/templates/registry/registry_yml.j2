version: 0.1
log:
  level: info
  formatter: json
  fields:
    service: registry
storage:
  delete:
    enabled: true
  cache:
    blobdescriptor: inmemory
  filesystem:
    rootdirectory: /var/lib/registry
http:
  addr: 0.0.0.0:{{ registry.port }}
  host: https://{{ registry.domain }}
  relativeurls: false
  secret: {{ vault_registry_http_secret }}
  debug:
    addr: 0.0.0.0:5001
    prometheus:
      enabled: true
      path: /metrics
health:
  storagedriver:
    enabled: true
    interval: 10s
    threshold: 3
