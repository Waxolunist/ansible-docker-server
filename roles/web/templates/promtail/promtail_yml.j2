server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://loki:3100/loki/api/v1/push

scrape_configs:
  - job_name: timescaledb
    docker_sd_configs:
      - host: tcp://socket-proxy:2375
        refresh_interval: 5s
        filters:
          - name: name
            values: ["web_timescaledb"]
    relabel_configs:
      - source_labels: ['__meta_docker_container_name']
        regex: '/(.*)'
        target_label: container
      - source_labels: ['__meta_docker_container_log_stream']
        target_label: logstream
    pipeline_stages:
      # Docker log driver wraps each line in JSON: {"log":"...", "stream":"...", "time":"..."}
      - json:
          expressions:
            output: log
            stream: stream
      - output:
          source: output
      # Extract PostgreSQL log level as a label for filtering in Grafana
      - regex:
          source: output
          expression: '(?i)(?P<pg_level>LOG|FATAL|ERROR|WARNING|NOTICE|DEBUG\d?):\s+'
      - labels:
          pg_level:
