{
  "id": null,
  "uid": "container-status-page",
  "title": "Service Status",
  "tags": ["status", "uptime"],
  "style": "dark",
  "timezone": "Europe/Vienna",
  "editable": true,
  "graphTooltip": 0,
  "refresh": "1m",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Services Operational",
      "description": "Number of containers currently up out of 15 monitored.",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 12   },
              { "color": "green",  "value": 15   }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "wideLayout": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum(container_last_seen{name=~\"web_reverse-proxy|web_prometheus|web_node-exporter|web_cadvisor|web_socket-proxy|web_autoheal|web_grafana|photoprism|web_registry|web_pgadmin|minecraft|authelia|web_timescaledb|grafana-pg|photoprism-mariadb\"} > bool (time() - 90))",
          "instant": true,
          "legendFormat": "Services Up",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Overall Uptime (30d)",
      "description": "Average uptime across all monitored containers over the selected time range.",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 0.95 },
              { "color": "green",  "value": 0.99 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "avg(avg_over_time(container_up_bool{name=~\"web_reverse-proxy|web_prometheus|web_node-exporter|web_cadvisor|web_socket-proxy|web_autoheal|web_grafana|photoprism|web_registry|web_pgadmin|minecraft|authelia|web_timescaledb|grafana-pg|photoprism-mariadb\"}[$__range]))",
          "instant": true,
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Last Updated",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "dateTimeFromNow",
          "noValue": "Never"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "prometheus_ready * 1000",
          "instant": true,
          "legendFormat": "Prometheus",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "type": "row",
      "title": "Infrastructure",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }
    },

    {
      "id": 11,
      "type": "stat",
      "title": "Traefik",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Down",        "color": "red"   }, "1": { "text": "Operational", "color": "green" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "Down", "color": "red" } } }
          ],
          "color": { "mode": "thresholds" },
          "unit": "none",
          "noValue": "Down"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "container_last_seen{name=\"web_reverse-proxy\"} > bool (time() - 90)",
          "instant": true,
          "legendFormat": "Traefik",
          "refId": "A"
        }
      ]
    },

